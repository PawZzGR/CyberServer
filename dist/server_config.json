{
    "server": {
        "host": "0.0.0.0",
        "port": 5000
    },
    "database": {
        "file": "cybercafe.db"
    },
    "backup": {
        "enabled": true,
        "interval_hours": 24,
        "keep_backups": 7,
        "directory": "backups"
    },
    "logging": {
        "enabled": true,
        "level": "INFO",
        "file": "cybercafe.log",
        "max_bytes": 10485760,
        "backup_count": 5
    }
}